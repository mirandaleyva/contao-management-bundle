{
  "name": "mirandaleyva/contao-management-bundle",
  "type": "contao-bundle",
  "description": "Contao 5.7 bundle for managing courses and course dates.",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "contao/core-bundle": "^5.0",
    "contao/manager-plugin": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "MirandaLeyva\\ContaoManagementBundle\\": "src/"
    }
  },
  "extra": {
    "contao-manager-plugin": "MirandaLeyva\\ContaoManagementBundle\\ContaoManager\\Plugin"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "contao-components/installer": false,
      "php-http/discovery": false,
      "contao/manager-plugin": true
    }
  }
}
