{% if empty %}
    <p>{{ labels.empty }}</p>
{% else %}
    <div class="course-list">
        {% for course in courses %}
            <article class="course-item">
                <h2>{{ course.title }}</h2>

                {% if course.author %}
                    <p>
                        <strong>{{ labels.author }}:</strong>
                        {{ course.author }}
                    </p>
                {% endif %}

                {% if course.next_date %}
                    <p>
                        <strong>{{ labels.next_date }}:</strong>
                        {{ course.next_date }}
                    </p>
                {% endif %}

                {% if course.description %}
                    <div class="course-description">
                        {{ course.description|raw }}
                    </div>
                {% endif %}

                {% if course.detail_url %}
                    <p>
                        <a href="{{ course.detail_url }}">{{ labels.details }}</a>
                    </p>
                {% endif %}
            </article>
        {% endfor %}
    </div>
{% endif %}